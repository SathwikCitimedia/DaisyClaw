# DaisyClaw .env example
#
# Quick start:
# 1) Copy this file to `.env` (for local runs from this repo), OR to `~/.daisyclaw/.env` (for launchd/systemd daemons).
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.
#
# Env-source precedence for environment variables (highest -> lowest):
# process env, ./.env, ~/.daisyclaw/.env, then daisyclaw.json `env` block.
# Existing non-empty process env vars are not overridden by dotenv/config env loading.
# Note: direct config keys (for example `gateway.auth.token` or channel tokens in daisyclaw.json)
# are resolved separately from env loading and often take precedence over env fallbacks.

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
# Required if the gateway binds beyond loopback. Leave blank to have DaisyClaw
# auto-generate a token on first start, or provide your own using
# `openssl rand -hex 32`. The gateway will refuse to start if this is set to
# the documented example placeholder, so never copy-paste an example value
# from docs or tutorials into this file verbatim.
DAISYCLAW_GATEWAY_TOKEN=

# Optional alternative auth mode (use token OR password).
# DAISYCLAW_GATEWAY_PASSWORD=

# Optional path overrides (defaults shown for reference).
# DAISYCLAW_STATE_DIR=~/.daisyclaw
# DAISYCLAW_CONFIG_PATH=~/.daisyclaw/daisyclaw.json
# DAISYCLAW_HOME=~
# Docker setup stores auth profile encryption key material outside the mounted
# DaisyClaw state dir and mounts this host directory into the container.
# DAISYCLAW_AUTH_PROFILE_SECRET_DIR=/absolute/path/to/.daisyclaw-auth-profile-secrets

# Allowlist of extra directories that `$include` directives in daisyclaw.json may
# resolve files from. Path-list separated (':' on POSIX, ';' on Windows). Each
# entry is tilde-expanded. Without this, `$include` is confined to the directory
# containing daisyclaw.json.
# DAISYCLAW_INCLUDE_ROOTS=/etc/daisyclaw/shared:~/.daisyclaw/shared

# Optional: import missing keys from your login shell profile.
# DAISYCLAW_LOAD_SHELL_ENV=1
# DAISYCLAW_SHELL_ENV_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Model provider API keys (set at least one)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# DAISYCLAW_LIVE_OPENAI_KEY=sk-...
# DAISYCLAW_LIVE_ANTHROPIC_KEY=sk-ant-...
# DAISYCLAW_LIVE_GEMINI_KEY=...
# OPENAI_API_KEY_1=...
# ANTHROPIC_API_KEY_1=...
# GEMINI_API_KEY_1=...
# GOOGLE_API_KEY=...
# OPENAI_API_KEYS=sk-1,sk-2
# ANTHROPIC_API_KEYS=sk-ant-1,sk-ant-2
# GEMINI_API_KEYS=key-1,key-2

# Optional additional providers
# ZAI_API_KEY=...
# AI_GATEWAY_API_KEY=...
# TOKENHUB_API_KEY=...
# LKEAP_API_KEY=...
# MINIMAX_API_KEY=...
# SYNTHETIC_API_KEY=...

# -----------------------------------------------------------------------------
# Channels (only set what you enable)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Optional channel env fallbacks
# MATTERMOST_BOT_TOKEN=...
# MATTERMOST_URL=https://chat.example.com
# ZALO_BOT_TOKEN=...
# DAISYCLAW_TWITCH_ACCESS_TOKEN=oauth:...

# -----------------------------------------------------------------------------
# Moodgraph emotional layer (optional — when set, all LLM responses are routed
# through the moodgraph API for humanoid emotional styling)
# -----------------------------------------------------------------------------
# MOODGRAPH_API_KEY=ds-free-...
# MOODGRAPH_SYSTEM_PROMPT=You are a helpful assistant.
#
# HOW IT WORKS: moodgraph generates THROUGH the user's configured LLM. moodgraph
# is a cloud service that calls the LLM itself, so it only works when it can reach
# that LLM from the public internet:
#   - OpenAI / Anthropic / Gemini keys  -> works directly (reachable public APIs).
#   - LiteLLM / local / internal proxy  -> moodgraph CANNOT reach an internal
#     address (e.g. http://10.x:4000). When that happens the gateway falls back to
#     the configured cloud LLM below so the reply is STILL moodgraph-styled.
# moodgraph only supports providers: openai, anthropic, gemini, custom. Other
# providers (litellm, openrouter, ...) are mapped to "custom" and require a
# publicly reachable base_url.
#
# Fallback cloud LLM — used when the user's own LLM is unreachable/unusable.
# Without this, unreachable-LLM users get the raw (un-styled) response.
# MOODGRAPH_FALLBACK_PROVIDER=anthropic        # openai | anthropic | gemini
# MOODGRAPH_FALLBACK_KEY=sk-ant-...            # real cloud key for that provider
# MOODGRAPH_FALLBACK_MODEL=claude-opus-4-8     # optional; defaults to session model
# MOODGRAPH_FALLBACK_BASE_URL=                 # optional; blank = provider default

# -----------------------------------------------------------------------------
# Tools + voice/media (optional)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=...

# ELEVENLABS_API_KEY=...
# XI_API_KEY=...  # alias for ElevenLabs
# INWORLD_API_KEY=...
# DEEPGRAM_API_KEY=...
