{
  "name": "@daisyclaw/brave-plugin",
  "version": "2026.6.2",
  "description": "DaisyClaw Brave Search provider plugin for web search.",
  "repository": {
    "type": "git",
    "url": "https://github.com/daisyclaw/daisyclaw"
  },
  "type": "module",
  "devDependencies": {
    "@daisyclaw/plugin-sdk": "workspace:*"
  },
  "daisyclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@daisyclaw/brave-plugin",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10",
      "allowInvalidConfigRecovery": true
    },
    "compat": {
      "pluginApi": ">=2026.6.2"
    },
    "build": {
      "daisyclawVersion": "2026.6.2"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
