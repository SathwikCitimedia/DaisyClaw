{
  "name": "@daisyclaw/codex",
  "version": "2026.6.2",
  "description": "DaisyClaw Codex app-server harness and model provider plugin with a Codex-managed GPT catalog.",
  "repository": {
    "type": "git",
    "url": "https://github.com/daisyclaw/daisyclaw"
  },
  "type": "module",
  "dependencies": {
    "@openai/codex": "0.139.0",
    "typebox": "1.1.39",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@daisyclaw/plugin-sdk": "workspace:*"
  },
  "daisyclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@daisyclaw/codex",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.1-beta.1"
    },
    "compat": {
      "pluginApi": ">=2026.6.2"
    },
    "build": {
      "daisyclawVersion": "2026.6.2"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true,
      "bundleRuntimeDependencies": false
    }
  }
}
