{
  "name": "@daisyclaw/google-meet",
  "version": "2026.6.2",
  "description": "DaisyClaw Google Meet participant plugin for joining calls through Chrome or Twilio transports.",
  "repository": {
    "type": "git",
    "url": "https://github.com/daisyclaw/daisyclaw"
  },
  "type": "module",
  "dependencies": {
    "commander": "14.0.3",
    "typebox": "1.1.39"
  },
  "devDependencies": {
    "@daisyclaw/plugin-sdk": "workspace:*",
    "daisyclaw": "workspace:*"
  },
  "peerDependencies": {
    "daisyclaw": ">=2026.6.2"
  },
  "peerDependenciesMeta": {
    "daisyclaw": {
      "optional": true
    }
  },
  "daisyclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@daisyclaw/google-meet",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.20"
    },
    "compat": {
      "pluginApi": ">=2026.6.2"
    },
    "build": {
      "daisyclawVersion": "2026.6.2"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
