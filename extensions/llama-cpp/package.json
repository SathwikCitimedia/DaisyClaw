{
  "name": "@daisyclaw/llama-cpp-provider",
  "version": "2026.6.2",
  "description": "DaisyClaw llama.cpp embedding provider plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/daisyclaw/daisyclaw"
  },
  "type": "module",
  "dependencies": {
    "node-llama-cpp": "3.18.1"
  },
  "devDependencies": {
    "@daisyclaw/plugin-sdk": "workspace:*"
  },
  "daisyclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@daisyclaw/llama-cpp-provider",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.6.2"
    },
    "compat": {
      "pluginApi": ">=2026.6.2"
    },
    "build": {
      "daisyclawVersion": "2026.6.2"
    },
    "release": {
      "bundleRuntimeDependencies": false,
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
