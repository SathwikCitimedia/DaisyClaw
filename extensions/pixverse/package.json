{
  "name": "@daisyclaw/pixverse-provider",
  "version": "2026.6.2",
  "description": "DaisyClaw PixVerse video generation provider plugin.",
  "repository": {
    "type": "git",
    "url": "https://github.com/daisyclaw/daisyclaw"
  },
  "type": "module",
  "devDependencies": {
    "@daisyclaw/plugin-sdk": "workspace:*",
    "daisyclaw": "workspace:*"
  },
  "peerDependencies": {
    "daisyclaw": ">=2026.6.2"
  },
  "peerDependenciesMeta": {
    "daisyclaw": {
      "optional": true
    }
  },
  "daisyclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "clawhubSpec": "clawhub:@daisyclaw/pixverse-provider",
      "npmSpec": "@daisyclaw/pixverse-provider",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.26"
    },
    "compat": {
      "pluginApi": ">=2026.6.2"
    },
    "build": {
      "daisyclawVersion": "2026.6.2",
      "bundledDist": false
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
