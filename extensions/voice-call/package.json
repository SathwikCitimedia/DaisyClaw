{
  "name": "@daisyclaw/voice-call",
  "version": "2026.6.2",
  "description": "DaisyClaw voice-call plugin for Twilio, Telnyx, and Plivo phone calls.",
  "repository": {
    "type": "git",
    "url": "https://github.com/daisyclaw/daisyclaw"
  },
  "type": "module",
  "dependencies": {
    "commander": "14.0.3",
    "typebox": "1.1.39",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@daisyclaw/plugin-sdk": "workspace:*",
    "daisyclaw": "workspace:*"
  },
  "peerDependencies": {
    "daisyclaw": ">=2026.6.2"
  },
  "peerDependenciesMeta": {
    "daisyclaw": {
      "optional": true
    }
  },
  "daisyclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@daisyclaw/voice-call",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.6.2"
    },
    "build": {
      "daisyclawVersion": "2026.6.2"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
